{
  "name": "railsense",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "worker": "node -r ts-node/register scripts/snapshotWorker.ts",
    "train-model": "python scripts/train_model.py",
    "demo": "concurrently \"npm run dev\" \"sleep 3 && npm run worker\"",
