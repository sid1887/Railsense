    "autoprefixer": "^10.4.0",
    "axios": "^1.13.6",
    "framer-motion": "^10.16.0",
    "fs-extra": "^11.3.4",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.263.0",
    "next": "^14.0.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
